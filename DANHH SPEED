-- LOAD TRACKER (os.clock resets to ~0 each Roblox open, so if saved > current = new session)
-- ========================
local COUNT_FILE = "izkNy_count.txt"
local CLOCK_FILE = "izkNy_clock.txt"

local currentClock = os.clock()
local savedClock = math.huge
local loadCount = 0

pcall(function() savedClock = tonumber(readfile(CLOCK_FILE)) or math.huge end)

if currentClock >= savedClock then
    -- savedClock is less than or equal to current = same Roblox session, keep counting
    pcall(function() loadCount = tonumber(readfile(COUNT_FILE)) or 0 end)
end
-- If currentClock < savedClock = Roblox restarted, loadCount stays 0

loadCount = loadCount + 1

pcall(function()
    writefile(CLOCK_FILE, tostring(currentClock))
    writefile(COUNT_FILE, tostring(loadCount))
end)

instantLog(string.format("Load tracker: %d load(s) this session", loadCount), "INFO")
